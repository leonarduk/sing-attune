# FastAPI CORS allowlist for browser-based frontends.
# Example: CORS_ORIGINS=http://localhost:5173,https://app.example.com
CORS_ORIGINS=

# Set to 1/true/yes/on for packaged Electron builds.
# Electron mode forces permissive CORS (allow_origins=["*"]) so file:// and app:// renderers can reach the backend.
ELECTRON_MODE=
